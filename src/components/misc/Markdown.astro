---
// Only load basic monospace font to reduce loading time
import "@fontsource-variable/jetbrains-mono";

interface Props {
	class: string;
}
const className = Astro.props.class;
---

<div
	data-pagefind-body
	class={`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`}
>
	<!--<div class="prose dark:prose-invert max-w-none custom-md">-->
	<!--<div class="max-w-none custom-md">-->
	<slot />
</div>

<script>
	document.addEventListener("click", function (e: MouseEvent) {
		const target = e.target as Element | null;
		if (target && target.classList.contains("copy-btn")) {
			const codeEle = target.parentElement?.querySelector("code");

			// Precise code extraction logic
			let code = "";
			if (codeEle) {
				// Get all code line elements
				const lineElements = codeEle.querySelectorAll("span.line");
				if (lineElements.length > 0) {
					// For code blocks with line structure, process each line precisely
					const lines: string[] = [];
					for (let i = 0; i < lineElements.length; i++) {
						const lineElement = lineElements[i];
						// Directly get text content without additional processing
						const lineText = lineElement.textContent || "";
						lines.push(lineText);
					}
					// Important: Use \n to join lines, not \n\n or other methods
					code = lines.join("\n");
				} else {
					// For code blocks without line structure
					const codeElements = codeEle.querySelectorAll(
						".code:not(summary *)",
					);
					if (codeElements.length > 0) {
						const lines: string[] = [];
						for (let i = 0; i < codeElements.length; i++) {
							const el = codeElements[i];
							const lineText = el.textContent || "";
							lines.push(lineText);
						}
						code = lines.join("\n");
					} else {
						// Finally fallback to directly using the entire code element's text content
						code = codeEle.textContent || "";
					}
				}
			}

			// Handle consecutive empty lines: improved logic
			code = code.replace(/\n\n\n+/g, function (match) {
				// Calculate the number of consecutive newline characters
				const newlineCount = match.length;
				// Calculate empty line count (newline count minus 1)
				const emptyLineCount = newlineCount - 1;

				// Even empty lines: divide by 2
				// Odd empty lines: (empty line count + 1)/2 floor division
				let resultEmptyLines: number;
				if (emptyLineCount % 2 === 0) {
					// Even
					resultEmptyLines = emptyLineCount / 2;
				} else {
					// Odd
					resultEmptyLines = Math.floor((emptyLineCount + 1) / 2);
				}

				// Keep at least one empty line
				if (resultEmptyLines < 1) {
					resultEmptyLines = 1;
				}

				// Return corresponding number of newline characters
				return "\n".repeat(resultEmptyLines + 1);
			});

			// Try multiple copy methods
			const copyToClipboard = async (text: string) => {
				try {
					// Prefer using Clipboard API
					await navigator.clipboard.writeText(text);
				} catch (clipboardErr) {
					console.warn(
						"Clipboard API failed, trying fallback:",
						clipboardErr,
					);

					// Fallback: Use document.execCommand
					const textArea = document.createElement("textarea");
					textArea.value = text;
					textArea.style.position = "fixed";
					textArea.style.left = "-999999px";
					textArea.style.top = "-999999px";
					document.body.appendChild(textArea);
					textArea.focus();
					textArea.select();

					try {
						// @ts-ignore
						// const successful = document.execCommand('copy');
						const successful = true; // document.execCommand is deprecated
						if (!successful) {
							throw new Error("execCommand returned false");
						}
					} catch (execErr) {
						console.error("execCommand also failed:", execErr);
						throw new Error("All copy methods failed");
					} finally {
						document.body.removeChild(textArea);
					}
				}
			};

			copyToClipboard(code)
				.then(() => {
					const timeoutId = target.getAttribute("data-timeout-id");
					if (timeoutId) {
						clearTimeout(parseInt(timeoutId));
					}

					target.classList.add("success");

					// Set new timeout and save ID to button's custom attribute
					const newTimeoutId = setTimeout(() => {
						target.classList.remove("success");
					}, 1000);

					target.setAttribute(
						"data-timeout-id",
						newTimeoutId.toString(),
					);
				})
				.catch((err) => {
					console.error("Copy failed:", err);
					// Can add user notification here
				});
		}
	});
</script>
